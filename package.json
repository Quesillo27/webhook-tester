{
  "name": "webhook-tester",
  "version": "1.1.1",
  "description": "App to receive and visualize webhooks in real-time via browser — like webhook.site but self-hosted",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit --testTimeout=15000",
    "docker": "docker build -t webhook-tester ."
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "webhook",
    "tester",
    "debug",
    "realtime",
    "sse"
  ],
  "author": "Quesillo27",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "nanoid": "^3.3.7",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
